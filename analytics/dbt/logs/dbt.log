  create  table "gastos_publicos"."gold_gold"."dim_orgao__dbt_tmp"
  
  
    as
  
  (
    select
    
    upper(
        trim(
            regexp_replace(orgao, '\s+', ' ', 'g')
        )
    )
 as orgao,
    orgao_superior,
    count(distinct ano) as anos_com_dados,
    min(ano) as primeiro_ano,
    max(ano) as ultimo_ano,
    sum(pago) as total_historico

from "gastos_publicos"."gold"."int_gastos_normalizado"

group by 1, 2
order by total_historico desc
  );
  
